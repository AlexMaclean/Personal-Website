{
  "private": true,
  "scripts": {
    "build": "esbuild src/main.ts --bundle --minify --loader:.glsl=text --outfile=assets/js/main.bundle.js",
    "watch": "esbuild src/main.ts --bundle --sourcemap --loader:.glsl=text --outfile=assets/js/main.bundle.js --watch",
    "dev": "concurrently -n js,jekyll -c blue,green \"npm run watch\" \"bundle exec jekyll serve --livereload\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/three": "^0.183.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2"
  }
}
